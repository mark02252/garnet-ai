{
  "name": "garnet",
  "version": "0.2.3",
  "private": true,
  "description": "Garnet all-in-one AI marketing OS for macOS",
  "main": "dist-electron/main.js",
  "scripts": {
    "stop:dev": "pkill -f \"next dev -p 3000\" || true; pkill -f \"ELECTRON_START_URL=http://localhost:3000 electron\" || true; pkill -f \"wait-on tcp:3000\" || true",
    "clean:cache": "chmod -R u+w .next .next-build 2>/dev/null || true; rm -rf .next .next-build node_modules/.cache || true",
    "dev": "npm run stop:dev && npm run clean:cache && npm run dev:fast",
    "dev:fast": "concurrently -k \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:clean": "npm run stop:dev && npm run clean:cache && npm run dev:fast",
    "dev:next": "next dev -p 3000 --turbo",
    "dev:electron": "wait-on tcp:3000 && npm run build:electron && cross-env NODE_ENV=development ELECTRON_START_URL=http://localhost:3000 electron .",
    "prepare:prisma-bundle": "rm -rf vendor_prisma && mkdir -p vendor_prisma && cp -R node_modules/.prisma vendor_prisma/.prisma",
    "build:next": "cross-env NEXT_DIST_DIR=.next-build next build && mkdir -p .next-build/standalone/.next-build && cp -R .next-build/static .next-build/standalone/.next-build/static",
    "build": "npm run prepare:prisma-bundle && npm run build:next && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "mcp:server": "node scripts/mcp-server.mjs",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status -o env",
    "supabase:db:reset": "npx supabase db reset",
    "supabase:db:push": "npx supabase db push",
    "supabase:gen:types": "npx supabase gen types typescript --local > lib/supabase/database.types.ts",
    "start": "next start -p 3000",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "dist": "npm run build && electron-builder --mac",
    "dist:publish": "npm run build && electron-builder --mac --publish always",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^6.4.1",
    "@supabase/supabase-js": "^2.99.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "mammoth": "^1.11.0",
    "next": "15.2.0",
    "openai": "^4.86.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "prisma": "^6.4.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.local.aimarketingdepartment",
    "productName": "Garnet",
    "asarUnpack": [
      ".next-build/**",
      "node_modules/ffmpeg-static/**"
    ],
    "files": [
      "dist-electron/**/*",
      ".next-build/standalone/**/*",
      ".next-build/standalone/.next-build/**/*",
      ".next-build/static/**/*",
      "vendor_prisma/**/*",
      "public/**/*",
      "prisma/**/*",
      "scripts/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/ffmpeg-static/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Garnet Installer"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "${env.APP_UPDATE_URL}"
      }
    ]
  }
}
