DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase local / hosted backend
# Local defaults come from `npm run supabase:start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Paste the local anon/publishable key from `npm run supabase:status`
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional fallback if your project still exposes the anon key name
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional remote project reference for CLI link/deploy flows
SUPABASE_PROJECT_REF=
# Optional token for `supabase link` / remote migrations
SUPABASE_ACCESS_TOKEN=

# Resend SMTP — Supabase Auth 이메일 발송
# 발급: https://resend.com → API Keys → Create API Key (Full access)
# config.toml의 [auth.email.smtp] pass = "env(RESEND_SMTP_PASSWORD)"
RESEND_SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 발신자 이메일 (Resend에서 도메인 인증 또는 기본 onboarding@resend.dev 사용 가능)
SMTP_ADMIN_EMAIL=noreply@yourdomain.com

# LLM provider: openai | local | gemini | groq | openclaw
LLM_PROVIDER=openai
# Run profile: manual | free
LLM_RUN_PROFILE=manual
# Optional: fallback order when primary provider fails
# Example: gemini,groq,openai,local,openclaw
LLM_FALLBACK_ORDER=
# Free mode provider priority
# Example: openclaw,groq,gemini,local
FREE_MODE_PROVIDER_ORDER=openclaw,groq,gemini,local
# If true, free mode can fallback to OpenAI when all free providers fail
FREE_MODE_ALLOW_PAID_FALLBACK=false

# OpenAI mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ADMIN_KEY=
OPENAI_MONTHLY_BUDGET_USD=

# Local LLM mode (OpenAI-compatible /v1)
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=

# Gemini mode
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_DAILY_LIMIT=20

# Groq mode
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenClaw mode (optional)
# If set LLM_PROVIDER=openclaw, app calls local `openclaw agent` CLI.
OPENCLAW_AGENT_ID=main
OPENCLAW_BIN=openclaw
OPENCLAW_TIMEOUT_SEC=120
OPENCLAW_FALLBACK_ON_GEMINI_QUOTA=true
SEMINAR_TICK_MS=45000

# Search
SEARCH_API_KEY=
SEARCH_PROVIDER=serper
SEARCH_INCLUDE_DOMAINS=
SEARCH_EXCLUDE_DOMAINS=

# Meta Instagram Reach Agent
# Long-lived user access token with Instagram insights permission
META_ACCESS_TOKEN=
# Instagram Business Account ID (ig-user-id)
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional Graph API version (default: v22.0)
META_GRAPH_API_VERSION=v22.0
# Optional lookback window in days for each run (default: 30)
INSTAGRAM_AGENT_LOOKBACK_DAYS=30
# Optional secret for protecting POST /api/instagram/reach/agent
INSTAGRAM_AGENT_SECRET=

# Desktop auto-update feed (generic provider)
# Example: https://your-domain.com/updates/mac
APP_UPDATE_URL=
