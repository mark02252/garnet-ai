{
  "name": "garnet",
  "version": "0.5.0",
  "private": true,
  "description": "Garnet all-in-one AI marketing OS for macOS",
  "scripts": {
    "stop:dev": "pkill -f \"next dev -p 3000\" || true",
    "clean:cache": "chmod -R u+w .next .next-build 2>/dev/null || true; rm -rf .next .next-build node_modules/.cache || true",
    "dev": "npm run stop:dev && npm run clean:cache && npm run dev:next",
    "dev:next": "next dev -p 3000",
    "dev:tauri": "npm run stop:dev && npm run clean:cache && tauri dev",
    "build:next": "cross-env NEXT_OUTPUT=standalone NEXT_DIST_DIR=.next-build next build && mkdir -p .next-build/standalone/.next-build && cp -R .next-build/static .next-build/standalone/.next-build/static",
    "build": "npm run build:next && tauri build",
    "build:vercel": "next build",
    "prepare:prisma-bundle": "rm -rf vendor_prisma && mkdir -p vendor_prisma && cp -R node_modules/.prisma vendor_prisma/.prisma",
    "mcp:server": "node scripts/mcp-server.mjs",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status -o env",
    "supabase:db:reset": "npx supabase db reset",
    "supabase:db:push": "npx supabase db push",
    "supabase:gen:types": "npx supabase gen types typescript --local > lib/supabase/database.types.ts",
    "start": "next start -p 3000",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "dist": "npm run build && electron-builder --mac",
    "dist:publish": "npm run build && electron-builder --mac --publish always",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-analytics/data": "^5.2.1",
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^6.4.1",
    "@supabase/supabase-js": "^2.99.1",
    "cmdk": "^1.1.1",
    "croner": "^8.1.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "mammoth": "^1.11.0",
    "next": "^15.5.14",
    "openai": "^4.86.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "pptxgenjs": "^4.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tesseract.js": "^7.0.0",
    "toad-scheduler": "^3.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.3",
    "prisma": "^6.4.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "tapiConfig": {
    "note": "Tauri handles bundling — see src-tauri/tauri.conf.json"
  }
}
