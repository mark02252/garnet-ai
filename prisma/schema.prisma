generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MeetingRole {
  STRATEGIST
  CONTENT_DIRECTOR
  PERFORMANCE_MARKETER
  OPERATIONS_MANAGER
  PM
}

enum DeliverableType {
  CAMPAIGN_PLAN
  CONTENT_PACKAGE
  EXPERIMENT_DESIGN
}

model Run {
  id              String       @id @default(uuid())
  topic           String
  brand           String?
  region          String?
  goal            String?
  flowTemplateId  String?
  createdAt       DateTime     @default(now())
  webSources      WebSource[]
  meetingTurns    MeetingTurn[]
  attachments     RunAttachment[]
  deliverable     Deliverable?
  memoryLog       MemoryLog?
  learningArchives LearningArchive[]
  runProgress     RunProgress?

  @@index([createdAt])
  @@index([topic])
  @@index([flowTemplateId, createdAt])
  @@index([brand])
}

model RunAttachment {
  id        String   @id @default(cuid())
  runId     String
  name      String
  mimeType  String
  content   String
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}

model WebSource {
  id        String   @id @default(cuid())
  runId     String
  title     String
  snippet   String
  url       String
  provider  String
  fetchedAt DateTime
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([fetchedAt])
}

model MeetingTurn {
  id        String      @id @default(cuid())
  runId     String
  role      MeetingRole
  nickname  String
  content   String
  createdAt DateTime    @default(now())
  run       Run         @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([role])
}

model Deliverable {
  id        String          @id @default(cuid())
  runId     String          @unique
  type      DeliverableType
  content   String
  createdAt DateTime        @default(now())
  run       Run             @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([type])
}

model MemoryLog {
  id             String   @id @default(cuid())
  runId          String   @unique
  hypothesis     String
  direction      String
  expectedImpact String
  risks          String
  outcome        String?
  failureReason  String?
  tags           String
  createdAt      DateTime @default(now())
  run            Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

enum DatasetType {
  CSV
  XLSX
  JSON
  TEXT
}

model Dataset {
  id        String      @id @default(cuid())
  name      String
  type      DatasetType
  notes     String?
  rawData   String
  analysis  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([createdAt])
  @@index([name])
  @@index([type])
}

enum LearningStatus {
  DRAFT
  CONFIRMED
  ARCHIVED
}

enum ReachTrendDirection {
  UP
  DOWN
  FLAT
}

model LearningArchive {
  id                  String         @id @default(cuid())
  runId               String?
  sourceType          String
  situation           String
  recommendedResponse String
  reasoning           String
  signals             String
  tags                String
  status              LearningStatus @default(DRAFT)
  lastUsedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  run                 Run?           @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([status])
  @@index([createdAt])
}

enum CampaignRoomManualStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model ManualCampaignRoom {
  id        String                    @id @default(cuid())
  title     String
  brand     String
  region    String
  goal      String
  objective String?
  notes     String?
  status    CampaignRoomManualStatus  @default(ACTIVE)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([brand])
  @@index([createdAt])
}

enum KpiPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

model KpiGoal {
  id           String    @id @default(cuid())
  title        String
  brand        String?
  region       String?
  metric       String
  targetValue  Float
  currentValue Float     @default(0)
  unit         String    @default("")
  period       KpiPeriod @default(MONTHLY)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
  @@index([brand])
}

model InstagramReachDaily {
  id         String   @id @default(cuid())
  accountId  String
  metricDate DateTime
  reach      Int
  rawValue   String?
  fetchedAt  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountId, metricDate])
  @@index([metricDate])
  @@index([accountId, metricDate])
}

model ContentDraft {
  id                String   @id @default(cuid())
  contentType       String
  brand             String   @default("")
  target            String   @default("")
  tone              String   @default("")
  keyMessage        String
  additionalContext String   @default("")
  result            String
  createdAt         DateTime @default(now())

  @@index([createdAt])
}

model InstagramReachAnalysisRun {
  id                  String              @id @default(cuid())
  accountId           String
  since               DateTime
  until               DateTime
  days                Int
  averageReach        Float
  latestReach         Int
  previousReach       Int?
  dayOverDayChangePct Float?
  sevenDayAverage     Float?
  trendDirection      ReachTrendDirection
  anomalyCount        Int                 @default(0)
  summary             String
  rawJson             String
  createdAt           DateTime            @default(now())

  @@index([accountId, createdAt])
  @@index([createdAt])
}

model ApprovalDecision {
  id        String   @id @default(cuid())
  itemType  String
  itemId    String
  decision  String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([itemType, itemId, decision])
  @@index([itemType, updatedAt])
}

model RunProgress {
  runId       String    @id
  status      String
  stepKey     String
  stepLabel   String
  progressPct Int       @default(0)
  message     String?
  startedAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  finishedAt  DateTime?

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model SeminarSession {
  id                 String          @id @default(cuid())
  title              String?
  topic              String
  brand              String?
  region             String?
  goal               String?
  status             String
  startsAt           DateTime
  endsAt             DateTime
  intervalMinutes    Int
  maxRounds          Int
  completedRounds    Int             @default(0)
  nextRunAt          DateTime?
  lastRunAt          DateTime?
  morningBriefing    String?
  runtimeConfig      String?
  lastError          String?
  isProcessing       Boolean         @default(false)
  processingStartedAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt
  rounds             SeminarRound[]
  finalReport        SeminarFinalReport?

  @@index([status, nextRunAt])
  @@index([createdAt])
}

model SeminarRound {
  id          String         @id @default(cuid())
  sessionId   String
  roundNumber Int
  scheduledAt DateTime
  startedAt   DateTime?
  finishedAt  DateTime?
  status      String
  runId       String?
  summary     String?
  error       String?
  createdAt   DateTime       @default(now())
  session     SeminarSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, roundNumber])
  @@index([sessionId, status])
  @@index([createdAt])
}

model SeminarFinalReport {
  id         String         @id @default(cuid())
  sessionId  String         @unique
  content    String
  structured String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @default(now()) @updatedAt
  session    SeminarSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

// ─── SNS 스튜디오 ─────────────────────────────

enum PersonaLearnMode {
  FROM_POSTS
  FROM_TEMPLATE
}

enum PersonaPlatform {
  INSTAGRAM
  THREADS
  X
  YOUTUBE
}

enum ContentType {
  TEXT
  CAROUSEL
  VIDEO
}

enum DraftStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum PlanningMode {
  CREATIVE
  SEARCH
  FILE
}

enum ScheduleStatus {
  PENDING
  PUBLISHED
  FAILED
  MISSED
}

// A. 페르소나
model SnsPersona {
  id              String           @id @default(cuid())
  name            String
  platform        PersonaPlatform  @default(INSTAGRAM)
  learnMode       PersonaLearnMode
  brandConcept    String?
  targetAudience  String?
  writingStyle    String?
  tone            String?
  keywords        String           @default("[]")
  sampleSentences String           @default("[]")
  instagramHandle String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  sourcePosts      SnsPersonaPost[]
  contentDrafts    SnsContentDraft[]
  scheduledPosts   SnsScheduledPost[]
  analytics        SnsAnalyticsSnapshot[]
  commentTemplates SnsCommentTemplate[]
  performanceReports SnsPerformanceReport[]
}

model SnsPersonaPost {
  id        String     @id @default(cuid())
  personaId String
  content   String
  postedAt  DateTime?
  source    String?
  persona   SnsPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId])
}

// B. 콘텐츠 초안
model SnsContentDraft {
  id           String          @id @default(cuid())
  personaId    String?
  type         ContentType     @default(TEXT)
  planningMode PlanningMode    @default(CREATIVE)
  title        String?
  content      String?
  slides       String?
  videoUrl     String?
  status       DraftStatus     @default(DRAFT)
  publishedAt  DateTime?
  platform     PersonaPlatform @default(INSTAGRAM)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  persona   SnsPersona?      @relation(fields: [personaId], references: [id], onDelete: SetNull)
  scheduled SnsScheduledPost[]

  @@index([personaId])
  @@index([createdAt])
  @@index([status])
}

// C. 예약 발행
model SnsScheduledPost {
  id          String          @id @default(cuid())
  draftId     String          @unique
  personaId   String
  platform    PersonaPlatform @default(INSTAGRAM)
  scheduledAt DateTime
  publishedAt DateTime?
  status      ScheduleStatus  @default(PENDING)
  errorMsg    String?
  createdAt   DateTime        @default(now())

  draft   SnsContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  persona SnsPersona      @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([personaId])
}

// D. 성과 스냅샷
model SnsAnalyticsSnapshot {
  id          String          @id @default(cuid())
  personaId   String
  platform    PersonaPlatform @default(INSTAGRAM)
  date        DateTime
  reach          Int             @default(0)
  impressions    Int             @default(0)
  engagement     Float           @default(0)
  followers      Int             @default(0)
  postCount      Int             @default(0)
  saved          Int             @default(0)
  shares         Int             @default(0)
  profileViews   Int             @default(0)
  websiteClicks  Int             @default(0)
  topPostId      String?
  createdAt   DateTime        @default(now())

  persona SnsPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([personaId, date])
}

// E. 댓글 템플릿
model SnsCommentTemplate {
  id              String     @id @default(cuid())
  personaId       String
  triggerKeywords String     @default("[]") // 미사용 — 향후 자동 답변 트리거 키워드 예정
  replyType       String     @default("comment")
  template        String
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())

  persona SnsPersona @relation(fields: [personaId], references: [id])

  @@index([personaId])
}

// F. 성과 리포트
model SnsPerformanceReport {
  id         String   @id @default(cuid())
  personaId  String
  period     String   @default("30d")
  reportJson String
  createdAt  DateTime @default(now())

  persona SnsPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId, createdAt])
}

// G. 콘텐츠 템플릿 라이브러리
model SnsContentTemplate {
  id             String      @id @default(cuid())
  name           String
  category       String      @default("GENERAL")
  type           ContentType @default(TEXT)
  promptTemplate String
  slideCount     Int         @default(5)
  hashtags       String      @default("[]")
  isActive       Boolean     @default(true)
  usageCount     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([category])
}

enum JobRunStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model JobRun {
  id          String       @id @default(cuid())
  jobId       String
  status      JobRunStatus
  message     String?
  durationMs  Int?
  error       String?
  createdAt   DateTime     @default(now())

  @@index([jobId, createdAt])
}

enum IntelPlatform {
  YOUTUBE
  TWITTER
  REDDIT
  SERPER
  NAVER
}

enum IntelUrgency {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum DigestType {
  DAILY
  URGENT
  WEEKLY
}

enum WatchCategory {
  BRAND
  COMPETITOR
  TREND
  GENERAL
}

model MarketingIntel {
  id           String        @id @default(cuid())
  platform     IntelPlatform
  query        String
  title        String
  snippet      String
  url          String
  publishedAt  DateTime?
  views        Int?
  likes        Int?
  comments     Int?
  shares       Int?
  relevance    Float         @default(0)
  urgency      IntelUrgency  @default(NORMAL)
  tags         String        @default("[]")
  raw          String?
  digestId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  digest       MarketingDigest? @relation(fields: [digestId], references: [id])

  @@unique([platform, url])
  @@index([platform, createdAt])
  @@index([urgency, createdAt])
  @@index([relevance])
}

model MarketingDigest {
  id           String           @id @default(cuid())
  type         DigestType
  headline     String
  summary      String
  insights     String
  actions      String
  itemCount    Int              @default(0)
  notifiedAt   DateTime?
  createdAt    DateTime         @default(now())
  items        MarketingIntel[]

  @@index([type, createdAt])
}

model WatchKeyword {
  id          String        @id @default(cuid())
  keyword     String
  category    WatchCategory @default(GENERAL)
  platforms   String        @default("[]")
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([isActive])
}

enum VideoFormat {
  REELS_9_16
  SHORTS_9_16
  TIKTOK_9_16
  SQUARE_1_1
  LANDSCAPE_16_9
}

enum VideoStatus {
  PENDING
  GENERATING
  EDITING
  COMPLETED
  FAILED
}

model VideoGeneration {
  id          String      @id @default(cuid())
  prompt      String
  format      VideoFormat  @default(REELS_9_16)
  platform    String      @default("instagram")
  status      VideoStatus @default(PENDING)
  script      String?
  videoUrl    String?
  thumbnailUrl String?
  durationSec Int?
  error       String?
  metadata    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  @@index([status, createdAt])
  @@index([platform])
}

model ResearchMemory {
  id        String   @id @default(cuid())
  title     String
  content   String?
  url       String?
  type      String   // "external" | "internal"
  tags      String   @default("[]") // JSON array string
  source    String?
  savedAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdAt])
}

model TechRadarItem {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String
  status      String   @default("assessing")
  description String?
  url         String?
  source      String?
  notes       String?                 // AI 분류 근거 또는 수동 메모
  tags        String   @default("[]")
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([status, category])
}

model FlowTemplate {
  id          String    @id @default(cuid())
  name        String
  description String?
  nodes       String    // JSON: FlowNode[]
  edges       String    // JSON: FlowEdge[]
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Phase 3: Episodic Memory ──

model EpisodicMemory {
  id          String   @id @default(cuid())
  category    String   // 'flow_run' | 'sns_post' | 'campaign' | 'ai_report'
  input       String   // 입력 요약 (주제, 브리프 등)
  output      String   // 결과 요약
  score       Float?   // 0-100 품질 점수 (Judge 또는 성과 기반)
  tags        String   @default("[]") // JSON: 관련 태그
  metadata    String   @default("{}") // JSON: 추가 메타데이터
  feedback    String?  // 사용자 또는 AI 피드백
  embedding   String?  // JSON array of 768 floats (nomic-embed-text via Ollama)
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([score])
  @@index([createdAt])
}

model ContentEvaluation {
  id              String   @id @default(cuid())
  mediaId         String   // Instagram media ID
  caption         String?
  mediaType       String?  // IMAGE, VIDEO, CAROUSEL_ALBUM
  publishedAt     DateTime
  evaluatedAt     DateTime @default(now())
  reach           Int      @default(0)
  impressions     Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  saved           Int      @default(0)
  shares          Int      @default(0)
  engagementRate  Float?
  performanceRank String?  // 'top10' | 'above_avg' | 'below_avg' | 'bottom10'
  patterns        String   @default("{}") // JSON: 추출된 패턴 (해시태그, 시간대, 유형 등)
  aiInsight       String?  // AI 분석 결과
  autoPlaybookId  String?  // 자동 생성된 플레이북 ID (있으면)

  @@unique([mediaId])
  @@index([performanceRank])
  @@index([publishedAt])
}

model RecommendationLog {
  id              String   @id @default(cuid())
  source          String   // 'ga4_ai' | 'sns_ai' | 'action_engine'
  recommendation  String   // 추천 내용
  predictedImpact String?  // 예상 효과
  actualResult    String?  // 실제 결과 (나중에 채움)
  accuracyScore   Float?   // 예측 vs 실제 정확도 (나중에 채움)
  createdAt       DateTime @default(now())
  evaluatedAt     DateTime?

  @@index([source])
  @@index([createdAt])
}

// ── Agent Loop ──

model WorldModelSnapshot {
  id        String   @id @default(cuid())
  data      String   // JSON: WorldModel type
  cycleType String   // urgency-check | routine-cycle | daily-briefing | weekly-review
  createdAt DateTime @default(now())

  @@index([cycleType])
  @@index([createdAt])
}

model GoalState {
  id              String   @id @default(cuid())
  goalName        String
  metric          String
  targetValue     String
  currentValue    String?
  progressPercent Float    @default(0)
  onTrack         Boolean  @default(true)
  checkedAt       DateTime @default(now())

  @@index([goalName])
}

model AgentLoopCycle {
  id             String   @id @default(cuid())
  cycleType      String
  status         String   @default("running") // running | completed | failed
  worldModelId   String?
  actionsCount   Int      @default(0)
  autoExecuted   Int      @default(0)
  sentToGovernor Int      @default(0)
  durationMs     Int      @default(0)
  summary        String?
  error          String?
  createdAt      DateTime @default(now())

  @@index([cycleType])
  @@index([createdAt])
  @@index([status])
}

// ── Knowledge Engine (Phase 1) ──

model KnowledgeEntry {
  id            String   @id @default(cuid())
  domain        String   // marketing, competitive, consumer, b2b, operations, finance, macro, self_improvement
  level         Int      @default(1) // 1=fact, 2=pattern, 3=principle
  pattern       String   // 조건/상황
  observation   String   // 관찰된 결과
  confidence    Float    @default(0.5)
  observedCount Int      @default(1)
  source        String   // "MONOPLEX 2026-Q2", "industry_article", etc
  isAntiPattern Boolean  @default(false)
  embedding     String?  // JSON array of 768 floats (nomic-embed-text via Ollama)
  relatedIds    String   @default("[]") // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([domain])
  @@index([level])
  @@index([confidence])
  @@index([isAntiPattern])
}

model PendingOutcome {
  id               String    @id @default(cuid())
  governorActionId String
  episodeId        String?
  actionKind       String
  metricsBefore    String    // JSON
  metricsAfter     String?   // JSON
  impactScore      Float?    // -100 ~ +100
  measureAt        DateTime
  measuredAt       DateTime?
  status           String    @default("pending") // pending | measured | expired
  createdAt        DateTime  @default(now())

  @@index([status, measureAt])
  @@index([actionKind])
}

// ── Causal Reasoning (Phase 3) ──

model CausalLink {
  id            String   @id @default(cuid())
  cause         String   // "content_publish:체험후기릴스"
  effect        String   // "engagement_increase_8pct"
  lag           String   // "3d"
  strength      Float    @default(0.5) // 0-1
  observedCount Int      @default(1)
  domain        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([cause])
  @@index([domain])
}
